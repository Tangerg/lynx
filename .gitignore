.idea
.vscode

# Lyra local config (holds API keys) — keep config.example.yaml only.
app/runtime/config/config.yaml

# Lyra dev binary (built via `go build -o lyra ./cmd/lyra`).
app/runtime/lyra

# Lyra dev-server runtime artifacts (written by `make restart` / `make start`).
app/runtime/lyra.log
app/runtime/lyra.pid

# Lyra runtime-generated memory (written to cwd when serving from app/runtime/).
app/runtime/LYRA.md