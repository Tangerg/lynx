{
  "messages": [
    {
      "role": "system",
      "parts": [{"kind": "text", "text": "You are precise."}]
    },
    {
      "role": "user",
      "parts": [
        {"kind": "text", "text": "Inspect these inputs."},
        {
          "kind": "media",
          "media": {
            "mime": "image/png",
            "source": {"kind": "bytes", "bytes": "aW1hZ2U="},
            "name": "diagram.png"
          }
        },
        {
          "kind": "media",
          "media": {
            "mime": "application/pdf",
            "source": {"kind": "reference", "ref": "file-123"},
            "name": "spec.pdf"
          }
        }
      ]
    },
    {
      "role": "assistant",
      "parts": [
        {"kind": "text", "text": "I will search."},
        {"kind": "tool_call", "tool_call": {"id": "call-1", "name": "search", "arguments": "{\"q\":\"lynx\"}"}}
      ],
      "metadata": {
        "openai/audio_id": "audio-prev",
        "openai/refusal": ""
      }
