{
  "protocolVersion": "2026-06-07",
  "clientInfo": {
    "name": "lyra-desktop",
    "version": "0.1.0"
  },
  "clientCapabilities": {
    "events": [
      "segment.started",
      "segment.progress",
      "segment.finished",
      "item.started",
      "item.delta",
      "item.completed",
      "state.snapshot",
      "state.delta",
      "custom"
    ],
    "features": {
      "multimodal": true
    },
    "interruptTypes": ["approval", "question"],
    "optOutNotificationMethods": ["item.delta"]
  }
}
