{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix",
    "typecheck": "tsc --noEmit",
    "knip": "knip",
    "check:circular": "node scripts/check-circular.mjs",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test && npm run knip && npm run check:circular",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "cd .. && frontend/node_modules/.bin/husky .husky"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "prettier --write",
      "oxlint --fix"
    ],
    "src/**/*.{js,jsx,json,md,css,html}": "prettier --write",
    "*.{json,md,js,cjs,ts}": "prettier --write"
  },
  "dependencies": {
    "@ag-ui/client": "^0.0.53",
    "@ag-ui/core": "^0.0.53",
    "@lobehub/icons": "^5.8.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/sdk-metrics": "^2.7.1",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-router": "^1.170.8",
    "beautiful-mermaid": "^1.1.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "colord": "^2.9.3",
    "compare-versions": "^6.1.1",
    "fast-json-patch": "^3.1.1",
    "i18next": "^26.2.0",
    "katex": "^0.17.0",
    "ky": "^2.0.2",
    "lucide-react": "^1.16.0",
    "motion": "^12.40.0",
    "nanoid": "^5.1.11",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-error-boundary": "^6.1.2",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark-breaks": "^4.0.0",
    "remark-cjk-friendly": "^2.0.1",
    "remark-gfm": "^4.0.1",
    "remark-github-blockquote-alert": "^2.1.0",
    "remark-math": "^6.0.0",
    "remend": "^1.3.0",
    "shiki": "^4.1.0",
    "sonner": "^2.0.7",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "unist-util-visit": "^5.1.0",
    "use-debounce": "^10.1.1",
    "use-stick-to-bottom": "^1.1.4",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/hast": "^3.0.4",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/ui": "^4.1.7",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "knip": "^6.14.2",
    "lint-staged": "^17.0.5",
    "madge": "^8.0.0",
    "oxlint": "^1.66.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
