{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint src --deny-warnings",
    "lint:fix": "oxlint src --fix --deny-warnings",
    "typecheck": "tsc --noEmit",
    "knip": "knip",
    "check:circular": "node scripts/check-circular.mjs",
    "check:layers": "node scripts/check-layers.mjs",
    "check:bundle": "vite build && node scripts/check-bundle-size.mjs",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test && npm run knip && npm run check:circular && npm run check:layers && npm run check:bundle",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "cd .. && frontend/node_modules/.bin/husky .husky"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "prettier --write",
      "oxlint --fix"
    ],
    "src/**/*.{js,jsx,json,md,css,html}": "prettier --write",
    "*.{json,md,js,cjs,ts}": "prettier --write"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@lobehub/icons": "^5.10.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.219.0",
    "@opentelemetry/core": "^2.8.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.219.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.219.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-logs": "^0.219.0",
    "@opentelemetry/sdk-metrics": "^2.8.0",
    "@opentelemetry/sdk-trace-web": "^2.8.0",
    "@tanstack/react-query": "^5.101.1",
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-virtual": "^3.14.4",
    "beautiful-mermaid": "^1.1.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "colord": "^2.9.3",
    "compare-versions": "^6.1.1",
    "eventsource-parser": "^3.1.0",
    "fast-json-patch": "^3.1.1",
    "i18next": "^26.3.3",
    "katex": "^0.17.0",
    "ky": "^2.0.2",
    "lucide-react": "^1.21.0",
    "motion": "^12.42.0",
    "nanoid": "^5.1.16",
    "quick-lru": "^7.3.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-error-boundary": "^6.1.2",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark-breaks": "^4.0.0",
    "remark-cjk-friendly": "^2.3.1",
    "remark-gfm": "^4.0.1",
    "remark-github-blockquote-alert": "^2.1.0",
    "remark-math": "^6.0.0",
    "remend": "^1.3.0",
    "shiki": "^4.3.0",
    "sonner": "^2.0.7",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "unist-util-visit": "^5.1.0",
    "use-debounce": "^10.1.1",
    "use-stick-to-bottom": "^1.1.6",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/hast": "^3.0.4",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/ui": "^4.1.9",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "knip": "^6.21.0",
    "lint-staged": "^17.0.8",
    "madge": "^8.0.0",
    "oxlint": "^1.71.0",
    "prettier": "^3.9.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
