# `legacy-peer-deps=true` — npm's peer-resolver became strict in v7+.
# We turned this on during the React 19 + Vite 8 jump because a handful
# of upstream packages (motion, @testing-library/*, react-i18next, …)
# still declared `react: ^18` in their peer ranges even though they
# already worked fine on React 19. Without this flag, `npm install`
# would refuse to resolve.
#
# Exit condition: drop this line once `npm ls react` no longer shows
# "peer dep" warnings against React 19. Until then it stays so
# contributors can clone + install in one go.
legacy-peer-deps=true
